{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://za38.internal/protocol/v2.json",
  "title": "za38 protocol v2",
  "x-protocol": {
    "major": 2,
    "minor": 5,
    "max_frame_bytes": 8388608,
    "max_tool_payload_bytes": 1048576,
    "client_methods": ["initialize", "run.start", "run.cancel", "context.compact", "config.show", "config.path", "models.list", "threads.list", "threads.open", "skills.list", "skills.inspect", "skills.set_enabled", "skills.install", "skills.update", "skills.remove", "skills.market.list", "shutdown"],
    "server_methods": ["event", "request"],
    "server_capabilities": ["run.cancel", "run.multithread", "interactive.approval", "interactive.question", "config.read", "models.read", "threads.read", "context.manage", "skills.read", "skills.manage"],
    "event_types": ["run.started", "skill.loaded", "content.delta", "thinking.delta", "tool.started", "tool.delta", "tool.completed", "context.updated", "interaction.resolved", "run.completed", "run.cancelled", "run.failed"]
  },
  "oneOf": [
    { "$ref": "#/$defs/jsonRpcRequest" },
    { "$ref": "#/$defs/jsonRpcNotification" },
    { "$ref": "#/$defs/jsonRpcSuccess" },
    { "$ref": "#/$defs/jsonRpcError" }
  ],
  "$defs": {
    "jsonRpcRequest": {
      "type": "object",
      "required": ["jsonrpc", "method", "id"],
      "properties": { "jsonrpc": { "const": "2.0" }, "method": { "type": "string" }, "id": { "type": "string" }, "params": { "type": "object" } },
      "additionalProperties": false
    },
    "jsonRpcNotification": {
      "type": "object",
      "required": ["jsonrpc", "method"],
      "properties": { "jsonrpc": { "const": "2.0" }, "method": { "type": "string" }, "params": { "type": "object" } },
      "additionalProperties": false
    },
    "jsonRpcSuccess": {
      "type": "object",
      "required": ["jsonrpc", "id", "result"],
      "properties": { "jsonrpc": { "const": "2.0" }, "id": { "type": "string" }, "result": {} },
      "additionalProperties": false
    },
    "jsonRpcErrorObject": {
      "type": "object",
      "required": ["code", "message"],
      "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": {} },
      "additionalProperties": false
    },
    "jsonRpcError": {
      "type": "object",
      "required": ["jsonrpc", "id", "error"],
      "properties": { "jsonrpc": { "const": "2.0" }, "id": { "type": ["string", "null"] }, "error": { "$ref": "#/$defs/jsonRpcErrorObject" } },
      "additionalProperties": false
    },
    "initializeParams": {
      "type": "object",
      "required": ["protocol", "client", "capabilities"],
      "properties": {
        "protocol": { "type": "object", "required": ["major", "min_minor", "max_minor"], "properties": { "major": { "const": 2 }, "min_minor": { "type": "integer", "minimum": 0 }, "max_minor": { "type": "integer", "minimum": 0 } }, "additionalProperties": false },
        "client": { "type": "object", "required": ["name", "version"], "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
        "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "cwd": { "type": "string" }, "config_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "threadSummary": {
      "type": "object",
      "required": ["thread_id", "created_at_ms", "updated_at_ms", "first_message", "latest_message", "message_count"],
      "properties": {
        "thread_id": { "type": "string", "minLength": 1 },
        "created_at_ms": { "type": "integer", "minimum": 0 },
        "updated_at_ms": { "type": "integer", "minimum": 0 },
        "first_message": { "type": "string" },
        "latest_message": { "type": "string" },
        "message_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "threadMessage": {
      "type": "object",
      "required": ["kind", "content"],
      "properties": {
        "kind": { "enum": ["user", "assistant", "tool"] },
        "content": { "type": "string" },
        "tool_name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "threadsListParams": {
      "type": "object",
      "properties": { "limit": { "type": "integer", "minimum": 1, "maximum": 200 } },
      "additionalProperties": false
    },
    "modelProfile": {
      "type": "object",
      "required": ["id", "model", "provider_label", "context_window_tokens", "capabilities", "is_default", "available", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "provider_label": { "type": "string", "minLength": 1 },
        "context_window_tokens": { "type": "integer", "minimum": 16384 },
        "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "is_default": { "type": "boolean" },
        "available": { "type": "boolean" },
        "unavailable_reason": { "type": ["string", "null"] },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "threadModelBinding": {
      "type": "object",
      "required": ["state", "roles"],
      "properties": {
        "state": { "enum": ["bound", "legacy", "unbound"] },
        "roles": { "type": "object", "additionalProperties": { "$ref": "#/$defs/modelProfile" } }
      },
      "additionalProperties": false
    },
    "modelsListParams": {
      "type": "object",
      "properties": { "thread_id": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    },
    "modelsListResult": {
      "type": "object",
      "required": ["profiles"],
      "properties": {
        "profiles": { "type": "array", "items": { "$ref": "#/$defs/modelProfile" } },
        "thread_binding": { "$ref": "#/$defs/threadModelBinding" }
      },
      "additionalProperties": false
    },
    "threadsListResult": {
      "type": "object",
      "required": ["threads"],
      "properties": { "threads": { "type": "array", "items": { "$ref": "#/$defs/threadSummary" } } },
      "additionalProperties": false
    },
    "threadsOpenParams": {
      "type": "object",
      "required": ["thread_id"],
      "properties": { "thread_id": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    },
    "threadsOpenResult": {
      "type": "object",
      "required": ["thread", "messages"],
      "properties": {
        "thread": { "$ref": "#/$defs/threadSummary" },
        "messages": { "type": "array", "items": { "$ref": "#/$defs/threadMessage" } }
      },
      "additionalProperties": false
    },
    "contextCompactParams": {
      "type": "object",
      "required": ["thread_id"],
      "properties": { "thread_id": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    },
    "contextCompactResult": {
      "type": "object",
      "required": ["compacted", "context"],
      "properties": { "compacted": { "type": "boolean" }, "context": { "type": "object" } },
      "additionalProperties": false
    },
    "eventEnvelope": {
      "type": "object",
      "required": ["event_id", "type", "thread_id", "run_id", "sequence", "timestamp_ms", "payload"],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 }, "type": { "type": "string", "minLength": 1 },
        "thread_id": { "type": "string", "minLength": 1 }, "run_id": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 }, "timestamp_ms": { "type": "integer", "minimum": 0 },
        "source": { "type": "object", "required": ["kind"], "properties": { "kind": { "enum": ["root", "subagent", "background"] }, "id": { "type": "string" }, "parent_tool_call_id": { "type": "string" } }, "additionalProperties": false },
        "payload": { "type": "object" }, "extensions": { "type": "object" }
      },
      "additionalProperties": false
    },
    "interactionRequest": {
      "type": "object",
      "required": ["request_id", "type", "thread_id", "run_id", "sequence", "timeout_ms", "payload"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 }, "type": { "enum": ["approval", "question"] },
        "thread_id": { "type": "string", "minLength": 1 }, "run_id": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 }, "timeout_ms": { "type": "integer", "minimum": 1 },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
